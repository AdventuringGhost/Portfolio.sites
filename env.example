# AdventuringGhost Monorepo Environment Variables
# Copy this file to .env and update with your actual values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DB_URI=mongodb://localhost:27017/adventuringghost
DB_HOST=localhost
DB_PORT=27017
DB_NAME=adventuringghost
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# =============================================================================
# AWS CONFIGURATION
# =============================================================================
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=your_aws_account_id

# =============================================================================
# API CONFIGURATION
# =============================================================================
VITE_API_URL=http://localhost:3000
API_URL=http://localhost:3000
API_PORT=3000
NODE_ENV=development

# Local Mongo (optional; used to persist quiz results locally)
MONGO_URI=mongodb://localhost:27017/adventuringghost
MONGO_DB=adventuringghost

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here
JWT_REFRESH_EXPIRES_IN=30d

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================
# Email Service (SendGrid, AWS SES, etc.)
EMAIL_SERVICE_API_KEY=your_email_service_api_key
EMAIL_FROM=noreply@adventuringghost.com

# File Storage (AWS S3, Cloudinary, etc.)
STORAGE_BUCKET=adventuringghost-storage
STORAGE_REGION=us-east-1

# =============================================================================
# DEVELOPMENT & DEBUGGING
# =============================================================================
DEBUG=adventuringghost:*
LOG_LEVEL=info
ENABLE_CORS=true
CORS_ORIGIN=http://localhost:5173

# =============================================================================
# MONITORING & ANALYTICS
# =============================================================================
# Sentry for error tracking
SENTRY_DSN=your_sentry_dsn_here

# Google Analytics
GA_TRACKING_ID=your_google_analytics_id

# =============================================================================
# THIRD-PARTY INTEGRATIONS
# =============================================================================
# Payment Processing (Stripe, PayPal, etc.)
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key

# Social Media APIs
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# =============================================================================
# DEPLOYMENT CONFIGURATION
# =============================================================================
# Production URLs
PRODUCTION_URL=https://adventuringghost.com
STAGING_URL=https://staging.adventuringghost.com

# CDN Configuration
CDN_URL=https://cdn.adventuringghost.com

# =============================================================================
# NOTES
# =============================================================================
# 1. Never commit actual .env files to version control
# 2. Use different values for development, staging, and production
# 3. Rotate secrets regularly
# 4. Use environment-specific configuration files when possible
# 5. Consider using AWS Secrets Manager or similar for production secrets
