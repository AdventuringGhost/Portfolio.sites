{
  "SecurityAlarms": [
    {
      "AlarmName": "High-Failed-Login-Attempts",
      "AlarmDescription": "Alert when there are multiple failed login attempts",
      "MetricName": "FailedLoginAttempts",
      "Namespace": "AWS/IAM",
      "Statistic": "Sum",
      "Period": 300,
      "EvaluationPeriods": 2,
      "Threshold": 10,
      "ComparisonOperator": "GreaterThanThreshold",
      "AlarmActions": [
        "arn:aws:sns:us-east-1:123456789012:SecurityAlerts"
      ],
      "OKActions": [
        "arn:aws:sns:us-east-1:123456789012:SecurityAlerts"
      ],
      "TreatMissingData": "notBreaching"
    },
    {
      "AlarmName": "Root-Account-Usage",
      "AlarmDescription": "Alert when root account is used",
      "MetricName": "RootAccountUsage",
      "Namespace": "AWS/IAM",
      "Statistic": "Sum",
      "Period": 300,
      "EvaluationPeriods": 1,
      "Threshold": 1,
      "ComparisonOperator": "GreaterThanOrEqualToThreshold",
      "AlarmActions": [
        "arn:aws:sns:us-east-1:123456789012:CriticalSecurityAlerts"
      ],
      "TreatMissingData": "notBreaching"
    },
