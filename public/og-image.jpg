<svg width="1200" height="630" viewBox="0 0 1200 630" fill="none" xmlns="http://www.w3.org/2000/svg">
  <rect width="1200" height="630" fill="url(#gradient)"/>
  
  <defs>
    <linearGradient id="gradient" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#59D5E0;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#F5DD61;stop-opacity:1" />
    </linearGradient>
  </defs>
  
  <!-- Background Pattern -->
  <circle cx="200" cy="150" r="80" fill="white" fill-opacity="0.1"/>
  <circle cx="1000" cy="480" r="120" fill="white" fill-opacity="0.1"/>
  <circle cx="600" cy="100" r="60" fill="white" fill-opacity="0.1"/>
  
  <!-- Main Content -->
  <text x="600" y="200" text-anchor="middle" font-family="Arial, sans-serif" font-size="48" font-weight="bold" fill="white">AdventuringGhost</text>
  <text x="600" y="260" text-anchor="middle" font-family="Arial, sans-serif" font-size="24" fill="white" fill-opacity="0.9">Cloud & DevOps Engineer</text>
  <text x="600" y="300" text-anchor="middle" font-family="Arial, sans-serif" font-size="18" fill="white" fill-opacity="0.8">AWS Developer Associate & Cisco CCNA</text>
  
  <!-- Tech Stack -->
  <text x="600" y="380" text-anchor="middle" font-family="Arial, sans-serif" font-size="16" fill="white" fill-opacity="0.7">Building resilient cloud infrastructure • Automating deployments • Securing networks</text>
  
  <!-- Website URL -->
  <text x="600" y="550" text-anchor="middle" font-family="Arial, sans-serif" font-size="20" fill="white" fill-opacity="0.8">adventuringghost.com</text>
</svg>

